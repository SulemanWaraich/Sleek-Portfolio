# Gallery: optional JSON URL with your media (see lib/gallery.ts shape). If unset or fetch fails:
# next Pexels if PEXELS_API_KEY is set, else built-in Picsum placeholders (no key).
GALLERY_JSON_ENDPOINT=

# Optional — Pexels (pexels.com/api). Used when GALLERY_JSON_ENDPOINT is unset or fails.
# PEXELS_API_KEY=
# Optional search query for the Pexels demo gallery (default: nature landscape)
# PEXELS_GALLERY_QUERY=

OPENAI_API_KEY=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — PostHog analytics (omit both to run without PostHog; key starts with phc_)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com